pipeline {
    agent any
    tools{
        nodejs 'nodejs23'
    }
    environment{
        SCANNER_HOME = tool 'sonar-scanner'
    }
    stages {
        stage('git-checkout') {
            steps {
                git branch: 'docker-build-deploy', url: 'https://github.com/jkabirqa/Multi-Tier-DevSecOps-Mega-Project.git'
            }
        }
         stage('fe compilation') {
            steps {
                dir('client') {
                    sh 'find . -name "*.js" -exec node --check {} +'
               }
            }
        }
        stage('be compilation') {
            steps {
                dir('api') {
                    sh 'find . -name "*.js" -exec node --check {} +'
               }
            }
        }
         stage('gitleaks') {
            steps {
                sh 'gitleaks detect --source ./client --exit-code 1'
                sh 'gitleaks detect --source ./api --exit-code 1'

            }
        }
         stage('sonarqube analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh '''$SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=NodeJS-Project \
                          -Dsonar.projectKey=NodeJS-Project '''
                }
            }
        }
         stage('QGateCheck') {
            steps {
                timeout(time: 1, unit: 'HOURS') {
                    waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
                }
            }
        }
         stage('trivy fS scan') {
            steps {
                sh 'trivy fs --format table -o fs-report.html .'
            }
        }
         stage('build & tag BE docker image') {
            steps {
                script{
                    // This step should not normally be used in your script. Consult the inline help for details.
                       withDockerRegistry(credentialsId: 'docker-creds') {
                         dir('api'){
                             sh 'docker build -t jkabirm/be:latest .'
                             sh 'trivy image --format table -o be-image-report jkabirm/be:latest'
                             sh 'docker push jkabirm/be:latest'
                         }
                    }
                }
            }
        }
        stage('build & tag FE docker image') {
            steps {
                script{
                    // This step should not normally be used in your script. Consult the inline help for details.
                       withDockerRegistry(credentialsId: 'docker-creds') {
                         dir('client'){
                             sh 'docker build -t jkabirm/fe:latest .'
                             sh 'trivy image --format table -o fe-image-report jkabirm/fe:latest'
                             sh 'docker push jkabirm/fe:latest'
                         }
                    }
                }
            }
        }
        stage('DOCKER deploy via Compose') {
            steps {
                script{
                    sh 'docker-compose up -d'
                }
            }
        }
    }
}
