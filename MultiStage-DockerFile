#stage1-Build
FROM node:22-slim AS BUILDER 
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY ..
RUN npm run build

#stage2-Production
FROM node:22-slim 
WORKDIR /app
COPY --from=builder app/dist ./dist
COPY --from=builder app/package*.json ./
RUN npm install --only=production
CMD ["node", "/dist/app.js"]
